{
  "version": 2,
  "name": "hermes-webui",
  "builds": [
    {
      "src": "static/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/**/*.py",
      "use": "@vercel/python",
      "config": {
        "includes": "/*.py"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*\\.js)", "dest": "/static/$1" },
    { "src": "/(.*\\.css)", "dest": "/static/$1" },
    { "src": "/(.*\\.png)", "dest": "/static/$1" },
    { "src": "/(.*\\.svg)", "dest": "/static/$1" },
    { "src": "/(.*\\.ico)", "dest": "/static/$1" },
    { "src": "/(.*\\.woff2?)", "dest": "/static/$1" },
    { "src": "/(.*)", "dest": "/static/index.html" }
  ]
}
